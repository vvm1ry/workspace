@app.route('/schedule')
def schedule_page():
    if 'user' not in session: return redirect('/login')
    username = session['user']
    nav = get_nav_for_user(username)
    right_panel = get_right_panel_for_user(username)

    all_groups = sorted(list(set(d['group'] for d in STUDENTS.values() if d['group'] != 'Директор')))

    if username == "director":
        html = "<div class='container' style='margin-top:90px;'><h1>Расписание</h1>"
        html += "<div class='glass'><h2>Выберите группу</h2>"
        html += "<ul class='group-list'>"
        for group in all_groups:
            html += f"<li class='group-item' onclick=\"window.location.href='/schedule/group/{group}'\"><span>{group}</span> <span style='opacity:0.6;'>→</span></li>"
        html += "</ul></div></div>"
        return STYLE + DIRECTOR_LEFT_PANEL_CONTENT + nav + right_panel + html

    student_data = STUDENTS.get(username, {})
    current_group = student_data.get("group", "")
    schedule = student_data.get("schedule", {})

    options = "".join([f"<option value='{g}' {'selected' if g == current_group else ''}>{g}</option>" for g in all_groups])

    html = f"""
    <div class='container' style='margin-top:90px;'>
        <h1>Расписание</h1>
        <div class='glass'>
            <h3>Моя группа: {current_group}</h3>
            <div class='group-select-container' style='margin:0; padding:10px 0; background:none;'>
                <select onchange="if(this.value) window.location.href='/schedule/group/'+this.value">
                    <option value="" disabled>Изменить группу...</option>
                    {options}
                </select>
            </div>
        </div>
        {render_schedule_content(current_group, schedule)}
    </div>
    """
    return STYLE + LEFT_PANEL_CONTENT + nav + right_panel + html

@app.route('/schedule/group/<group_name>')
def schedule_group(group_name):
    if 'user' not in session: return redirect('/login')
    username = session['user']
    source = request.args.get('source', '')

    nav = get_nav_for_user(username)
    right_panel = get_right_panel_for_user(username)

    target_username = None
    for user, data in STUDENTS.items():
        if data["group"] == group_name:
            target_username = user
            break

    if not target_username:
        msg = "<div class='container'><div class='glass'><h2>Ошибка</h2><p>Группа не найдена</p><a href='/schedule'>Назад</a></div></div>"
        if username == 'director': return STYLE + DIRECTOR_LEFT_PANEL_CONTENT + nav + right_panel + msg
        else: return STYLE + LEFT_PANEL_CONTENT + nav + right_panel + msg

    schedule = STUDENTS[target_username].get("schedule", {})

    back_link = f"<a href='/schedule' class='view-btn'>← Назад</a>"
    if source == 'search' and username == 'director':
        back_link = f"<a href='/director-search?q={group_name}' class='view-btn'>← К поиску</a>"

    html = f"<div class='container' style='margin-top:90px;'><h1>Группа {group_name}</h1>"
    html += render_schedule_content(group_name, schedule)
    html += "<div style='margin-top:20px;'>" + back_link + "</div></div>"

    if username == 'director': return STYLE + DIRECTOR_LEFT_PANEL_CONTENT + nav + right_panel + html
    else: return STYLE + LEFT_PANEL_CONTENT + nav + right_panel + html

@app.route('/consultations')
def consultations_page():
    if 'user' not in session: return redirect('/login')
    username = session['user']
    nav = get_nav_for_user(username)
    right_panel = get_right_panel_for_user(username)

    if username == "director":
        groups = sorted(list(set(d['group'] for d in STUDENTS.values() if d['group'] != 'Директор')))
        html = "<div class='container' style='margin-top:90px;'><h1>Консультации</h1>"
        html += "<div class='glass'><h2>Выберите группу</h2>"
        html += "<ul class='group-list'>"
        for group in groups:
            html += f"<li class='group-item' onclick=\"window.location.href='/consultations/group/{group}'\"><span>{group}</span> <span style='opacity:0.6;'>→</span></li>"
        html += "</ul></div></div>"
        return STYLE + DIRECTOR_LEFT_PANEL_CONTENT + nav + right_panel + html

    consultations = STUDENTS.get(username, {}).get("consultations", {})
    html="<div class='container' style='margin-top:90px;'><h1>Консультации</h1>"
    if not consultations:
        html += "<div class='glass'>Нет назначенных консультаций.</div>"
    else:
        for day,data in consultations.items():
            subj,room,time=data
            html+=f"<div class='glass'><h3>{day}</h3><p style='font-size:18px;'>{time} | <b>{subj}</b> — каб. {room}</p></div>"

    if username == 'director': return STYLE + DIRECTOR_LEFT_PANEL_CONTENT + nav + right_panel + html + "</div>"
    else: return STYLE + LEFT_PANEL_CONTENT + nav + right_panel + html + "</div>"

