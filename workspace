from flask import Flask, render_template_string, request, redirect, session, url_for
import random
import re

app = Flask(__name__)
app.secret_key = 'super_secret_key_123'

# Данные пользователей: логин -> пароль
USERS = {
    "student": "1234",
    "student2": "1234",
    "student3": "1234",
    "director": "1234"
}

# Ожидающие одобрения пользователи
PENDING_USERS = {}

# Одобренные пользователи
APPROVED_USERS = {"student", "student2", "student3", "director"}
RECENTLY_APPROVED = []  # Список недавно принятых аккаунтов

# Специальности и их предметы
SPECIALTIES = {
    100: ["Инженерия", "Высшая математика", "Физика", "Черчение", "Основы IT", "Механика"],
    200: ["Анатомия", "Биология", "Химия", "Латынь", "Основы медицины", "Физиология"],
    300: ["Экономика", "Бухгалтерский учет", "Финансы", "Статистика", "Менеджмент", "Право"],
    400: ["Иностранный язык", "Лингвистика", "Переводоведение", "Культурология", "Фонетика", "Грамматика"],
    600: ["Психология", "Социология", "Педагогика", "Возрастная психология", "Философия", "Логика"]
}

ALL_SUBJECTS = list(set(subj for subs in SPECIALTIES.values() for subj in subs))

# Данные студентов
STUDENTS = {
     "student": {"group": "К520С9-2", "specialty": "General", "schedule": {}, "consultations": {}, "grades": {}},
     "student2": {"group": "К305С9-1", "specialty": "General", "schedule": {}, "consultations": {}, "grades": {}},
     "student3": {"group": "К415С9-3", "specialty": "General", "schedule": {}, "consultations": {}, "grades": {}},
     "student4": {"group": "К520С9-2", "specialty": "General", "schedule": {}, "consultations": {}, "grades": {}},
     "student5": {"group": "К305С9-1", "specialty": "General", "schedule": {}, "consultations": {}, "grades": {}},
     "student6": {"group": "К415С9-3", "specialty": "General", "schedule": {}, "consultations": {}, "grades": {}},
     "student7": {"group": "К520С9-2", "specialty": "General", "schedule": {}, "consultations": {}, "grades": {}},
     "student8": {"group": "К305С9-1", "specialty": "General", "schedule": {}, "consultations": {}, "grades": {}},
     "student9": {"group": "К415С9-3", "specialty": "General", "schedule": {}, "consultations": {}, "grades": {}}

}

room_ranges = [
    list(range(100, 116)),
    list(range(200, 217)),
    list(range(300, 317)),
    list(range(400, 416))
]

week_days = ["Понедельник", "Вторник", "Среда", "Четверг", "Пятница", "Суббота"]
time_slots = [(8,9),(9,10),(10,11),(11,12),(12,13),(14,15),(15,16),(16,17),(17,18)]

def format_time(t):
    h = int(t)
    m = int((t - h) * 60)
    return f"{h:02d}:{m:02d}"

def get_specialty_code(group_name):
    if not group_name: return None
    match = re.search(r'К(\d+)', group_name)
    if match:
        code = int(match.group(1))
        return (code // 100) * 100
    return None

def generate_group_name(specialty_code=None):
    if specialty_code:
        num = specialty_code + random.randint(0, 99)
    else:
        num = random.choice([100, 200, 300, 400, 600]) + random.randint(0, 99)

    letter = random.randint(1, 9)
    suffix = random.randint(1, 3)
    return f"К{num}С{letter}-{suffix}"

def generate_data_for_student(username, specialty_code):
    subjects = SPECIALTIES.get(specialty_code, ["Общий предмет", "Физкультура"])

    schedule = {}
    for day in week_days:
        lessons = []
        if day == "Суббота":
            lessons = [(random.choice(subjects), "", "Лекция", None)]
        else:
            count = random.randint(2, 4)
            used_slots = sorted(random.sample(time_slots, min(count, len(time_slots))), key=lambda x: x[0])
            for start, end in used_slots:
                subj = random.choice(subjects)
                room = random.choice(random.choice(room_ranges))
                lessons.append((subj, room, f"{format_time(start)}-{format_time(end)}", start))
        schedule[day] = lessons

    consultations = {}
    for day in ["Понедельник", "Вторник", "Среда", "Четверг", "Пятница"]:
        start = random.choice([8, 9, 10, 11, 12, 13, 14, 15])
        room = random.choice(random.choice(room_ranges))
        subj = random.choice(subjects)
        consultations[day] = (subj, room, f"{start}:00-{start+1}:00")

    grades = {}
    for subj in subjects:
        max_pz = random.randint(10, 20)
        pz = [random.randint(40, 100) if i < max_pz else None for i in range(20)]
        grades[subj] = {"pz": pz, "max_pz": max_pz}

    if username in STUDENTS:
        STUDENTS[username]["schedule"] = schedule
        STUDENTS[username]["consultations"] = consultations
        STUDENTS[username]["grades"] = grades
        STUDENTS[username]["specialty"] = specialty_code

def register_user(username, password):
    if username in USERS or username in PENDING_USERS:
        return False, "Пользователь уже существует"

    if username == "director":
        USERS[username] = password
        if username not in APPROVED_USERS:
            APPROVED_USERS.add(username)
        if username not in STUDENTS:
            STUDENTS[username] = {"group": "Директор", "specialty": "Admin", "schedule": {}, "consultations": {}, "grades": {}}
        return True, "Аккаунт директора создан"
    else:
        PENDING_USERS[username] = password
        return True, "Заявка отправлена на одобрение"

def approve_user(username):
    if username in PENDING_USERS:
        password = PENDING_USERS.pop(username)
        USERS[username] = password
        APPROVED_USERS.add(username)

        spec_codes = [100, 200, 300, 400, 600]
        chosen_spec = random.choice(spec_codes)

        group = generate_group_name(chosen_spec)
        attempts = 0
        while group in [s["group"] for s in STUDENTS.values()] and attempts < 100:
            group = generate_group_name(chosen_spec)
            attempts += 1

        # Создаем запись студента с пустыми оценками
        STUDENTS[username] = {"group": group, "specialty": chosen_spec, "schedule": {}, "consultations": {}, "grades": {}}
        
        # Генерируем расписание и консультации (но НЕ оценки)
        subjects = SPECIALTIES.get(chosen_spec, ["Общий предмет"])
        
        # Генерация расписания
        schedule = {}
        for day in week_days:
            lessons = []
            if day == "Суббота":
                lessons = [(random.choice(subjects), "", "Лекция", None)]
            else:
                count = random.randint(2, 4)
                used_slots = sorted(random.sample(time_slots, min(count, len(time_slots))), key=lambda x: x[0])
                for start, end in used_slots:
                    subj = random.choice(subjects)
                    room = random.choice(random.choice(room_ranges))
                    lessons.append((subj, room, f"{format_time(start)}-{format_time(end)}", start))
            schedule[day] = lessons
        
        # Генерация консультаций
        consultations = {}
        for day in ["Понедельник", "Вторник", "Среда", "Четверг", "Пятница"]:
            start = random.choice([8, 9, 10, 11, 12, 13, 14, 15])
            room = random.choice(random.choice(room_ranges))
            subj = random.choice(subjects)
            consultations[day] = (subj, room, f"{start}:00-{start+1}:00")

        # Сохраняем сгенерированные данные
        STUDENTS[username]["schedule"] = schedule
        STUDENTS[username]["consultations"] = consultations
        # Grades оставляем пустыми {}

        # Добавляем в список недавно принятых
        RECENTLY_APPROVED.insert(0, {"username": username, "group": group, "specialty": chosen_spec})
        if len(RECENTLY_APPROVED) > 10:
            RECENTLY_APPROVED.pop()

        return True
    return False

def reject_user(username):
    if username in PENDING_USERS:
        del PENDING_USERS[username]
        return True
    return False

# Инициализация данных для старых студентов при запуске
def init_students_data():
    # Добавляем оценки для всех существующих студентов (student - student9)
    for username in ["student", "student2", "student3", "student4", "student5", "student6", "student7", "student8", "student9"]:
        if not STUDENTS[username]["schedule"]:
            group = STUDENTS[username]["group"]
            spec_code = get_specialty_code(group)
            if not spec_code or spec_code not in SPECIALTIES:
                spec_code = 100
            generate_data_for_student(username, spec_code)

init_students_data()

