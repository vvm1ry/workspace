@app.route('/chat', methods=['GET', 'POST'])
def chat():
    if 'user' not in session: return redirect('/login')
    username = session['user']
    if username == 'director': return redirect('/')

    nav = get_nav_for_user(username)
    right_panel = get_right_panel_for_user(username)

    if request.method == 'POST':
        msg = request.form.get('message', '')
        if msg:
            CHAT.append({"user": username, "msg": msg})
            return redirect('/chat')

    html = "<div class='container' style='margin-top:90px;'><h1>Чат с куратором</h1>"
    html += "<div class='glass' style='height: 400px; overflow-y: auto; margin-bottom: 20px; background: rgba(0,0,0,0.3);'>"
    if not CHAT:
        html += "<p style='text-align:center; opacity:0.5; margin-top:150px;'>История пуста</p>"
    else:
        for entry in CHAT:
            style = "text-align:right; color:#a5b4fc;" if entry['user'] == username else "text-align:left; color:#fff;"
            html += f"<p style='{style}'><b>{entry['user']}:</b> {entry['msg']}</p>"
    html += "</div>"

    html += """
    <div class='glass'>
        <form method='post'>
            <textarea name='message' rows='3' placeholder='Сообщение...'></textarea>
            <button type='submit'>Отправить</button>
        </form>
    </div>
    </div>
    """
    return STYLE + LEFT_PANEL_CONTENT + nav + right_panel + html

