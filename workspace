LEFT_PANEL_CONTENT = """
<div class='left-panel'>
    <h2>Аккаунт Студента</h2>
    <p>Добро пожаловать в личный кабинет. Здесь вы найдете всю необходимую информацию для успешной учебы.</p>

    <h3>Учебный процесс</h3>
    <ul>
        <li>Актуальное расписание занятий</li>
        <li>График консультаций с преподавателями</li>
        <li>Электронный журнал оценок</li>
        <li>Методические материалы</li>
    </ul>

    <h3>Важно</h3>
    <p>Следите за уведомлениями в правой панели. Не пропускайте контрольные точки и сдавайте практические задания вовремя.</p>

    <h3>Поддержка</h3>
    <p>Если у вас возникли вопросы, используйте чат с куратором или раздел FAQ.</p>
</div>
"""

DIRECTOR_LEFT_PANEL_CONTENT = """
<div class='director-panel'>
    <h2>Аккаунт Директора</h2>
    <p>Панель административного управления учебным процессом колледжа.</p>

    <h3>Управление</h3>
    <ul>
        <li>Мониторинг успеваемости групп</li>
        <li>Утверждение новых студентов</li>
        <li>Просмотр расписания всех потоков</li>
        <li>Рассылка уведомлений кураторам</li>
    </ul>

    <h3>Статистика</h3>
    <p>Система автоматически формирует отчеты по посещаемости и среднему баллу в реальном времени.</p>

    <h3>Быстрый доступ</h3>
    <p>Используйте поиск в правой панели для мгновенного нахождения любого студента или группы по номеру или фамилии.</p>
</div>
"""

def get_nav_for_user(username):
    if username == "director":
        return """<div class='navbar'><a href='/'>Главная</a><a href='/schedule'>Расписание</a><a href='/consultations'>Консультации</a><a href='/grades'>Оценки</a><a href='/materials'>Материалы</a><a href='/admin'>Админ-панель</a><a href='/logout'>Выход</a></div>"""
    else:
        return """<div class='navbar'><a href='/'>Главная</a><a href='/schedule'>Расписание</a><a href='/consultations'>Консультации</a><a href='/grades'>Оценки</a><a href='/materials'>Материалы</a><a href='/logout'>Выход</a></div>"""

def get_right_panel_for_user(username):
    if username == "director":
        return """<div class='rightpanel glass'><a href='/faq'>FAQ</a><a href='/notifications-director'>Оповещения</a><a href='/notifications'>Уведомления</a></div><div class='search glass'><form action='/director-search' method='GET'><input name='q' placeholder='Поиск (студент, группа, раздел)'></form></div>"""
    else:
        return """<div class='rightpanel glass'><a href='/faq'>FAQ</a><a href='/chat'>Чат с куратором</a><a href='/notifications'>Уведомления</a></div><div class='search glass'><form action='/search'><input name='q' placeholder='Поиск раздела'></form></div>"""

@app.route('/search')
def search():
    q = request.args.get('q', '').lower()
    routes = {
        "главная": "/", "расписание": "/schedule", "консультации": "/consultations",
        "оценки": "/grades", "материалы": "/materials", "faq": "/faq",
        "чат": "/chat", "уведомления": "/notifications"
    }
    for k, v in routes.items():
        if k in q:
            return redirect(v)

    if 'user' not in session: return redirect('/login')
    username = session['user']
    nav = get_nav_for_user(username)
    right_panel = get_right_panel_for_user(username)

    error_html = f"""
    <div class='container' style='margin-top:90px;'>
        <div class='glass'>
            <h2>Ничего не найдено</h2>
            <p>Раздел "<b>{request.args.get('q', '')}</b>" не найден.</p>
            <a href='/' class='view-btn'>На главную</a>
        </div>
    </div>
    """
    if username != 'director':
        return STYLE + LEFT_PANEL_CONTENT + nav + right_panel + error_html
    else:
        return STYLE + DIRECTOR_LEFT_PANEL_CONTENT + nav + right_panel + error_html

@app.route('/director-search')
def director_search():
    if 'user' not in session or session['user'] != 'director': return redirect('/login')
    query = request.args.get('q', '').strip()
    if not query: return redirect('/admin')

    nav = get_nav_for_user('director')
    right_panel = get_right_panel_for_user('director')

    # Поиск разделов
    routes = {
        "расписание": "/schedule", "оценки": "/grades", "консультации": "/consultations",
        "материалы": "/materials", "админ": "/admin", "уведомления": "/notifications"
    }
    for k, v in routes.items():
        if k in query.lower():
            return redirect(v)

    # Поиск пользователей
    found_users = []
    query_lower = query.lower()
    for user, data in STUDENTS.items():
        if user == 'director': continue
        group = data.get('group', '')
        if query_lower in user.lower() or query_lower in group.lower():
            found_users.append((user, data))

    html = "<div class='container' style='margin-top:90px;'><h1>Результаты поиска</h1>"
    if not found_users:
        html += f"<div class='glass'><p>Пользователи по запросу '{query}' не найдены. Попробуйте ввести имя студента или номер группы.</p><a href='/admin'>Назад в панель</a></div>"
    else:
        for user, data in found_users:
            group = data.get('group', 'Нет группы')
            password = USERS.get(user, 'Неизвестен')
            group_count = sum(1 for u, d in STUDENTS.items() if d.get('group') == group and u != 'director')

            html += f"""
            <div class='search-result-card'>
                <h2 style='margin-top:0;'>{user}</h2>
                <div style="margin: 10px 0; color: #cbd5e1;"><strong>Группа:</strong> {group} | <strong>Пароль:</strong> {password}</div>
                <div style="font-size: 13px; opacity: 0.7; margin-bottom: 15px;">Всего студентов в группе: {group_count}</div>
                <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                    <a href='/grades/student/{user}' class='view-btn'>📊 Оценки</a>
                    <a href='/schedule/group/{group}?source=search' class='view-btn'>📅 Расписание</a>
                    <a href='/consultations/group/{group}?source=search' class='view-btn'>💬 Консультации</a>
                </div>
            </div>
            """
    html += "</div>"
    return STYLE + DIRECTOR_LEFT_PANEL_CONTENT + nav + right_panel + html

@app.route('/public-schedule')
def public_schedule():
    groups = sorted(list(set(d['group'] for d in STUDENTS.values() if d['group'] != 'Директор')))
    selected_group = request.args.get('group', groups[0] if groups else '')

    schedule_data = {}
    if selected_group:
        for u, d in STUDENTS.items():
            if d['group'] == selected_group:
                schedule_data = d.get('schedule', {})
                break

    html = f"""
    <div class='container' style='margin-top:100px;'>
        <div class='public-header'>
            <h1>Публичное расписание</h1>
            <div class='public-nav'>
                <a href='/login' class='public-btn'>Вход</a>
                <a href='/register' class='public-btn'>Регистрация</a>
            </div>
        </div>

        <div class='glass'>
            <h2>Выберите группу</h2>
            <div class='group-select-container'>
                <form method='GET' action='/public-schedule'>
                    <select name='group' onchange='this.form.submit()'>
                        {''.join([f"<option value='{g}' {'selected' if g == selected_group else ''}>{g}</option>" for g in groups])}
                    </select>
                </form>
            </div>
        </div>

        {render_schedule_content(selected_group, schedule_data) if selected_group else "<div class='glass'>Выберите группу для просмотра</div>"}
    </div>
    """
    return STYLE + html

def render_schedule_content(group_name, schedule):
    if not schedule:
        return "<div class='glass'>Расписание формируется...</div>"

    html = f"<div class='schedule-grid'>"
    for day, lessons in schedule.items():
        html += f"<div class='day-card'><h3>{day}</h3>"
        if not lessons:
            html += "<p style='opacity:0.6; font-style:italic;'>Пар нет</p>"
        else:
            for item in lessons:
                subj, room, time = item[0], item[1], item[2]
                room_display = room if room else "—"
                html += f"""
                <div class='lesson-item'>
                    <span class='lesson-time'>{time}</span>
                    <span class='lesson-subj'>{subj}</span>
                    <span class='lesson-room'>{room_display}</span>
                </div>
                """
        html += "</div>"
    html += "</div>"
    return html

@app.route('/login', methods=['GET','POST'])
def login():
    if request.method=='POST':
        username = request.form.get('username', '')
        password = request.form.get('password', '')
        if USERS.get(username) == password:
            session['user'] = username
            return redirect('/')
        return STYLE+"<div class='container'><div class='glass'><h2>Ошибка</h2><p>Неверные данные</p><a href='/login'>Назад</a></div></div>"

    contact_info = """
    <div class='contact-info'>
        <strong>Контакты:</strong><br>
        Директор: +7 116 116 67 52<br>
        Email: college@mail.com
    </div>
    """
    return STYLE+f"""<div class='container'><div class='glass'><h2>Вход в систему</h2>
    <form method='post'>
        <input name='username' placeholder='Логин'>
        <input name='password' type='password' placeholder='Пароль'>
        <button>Войти</button>
    </form>
    <p style='margin-top:15px; text-align:center;'>Нет аккаунта? <a href='/register' style='color:#a5b4fc;'>Регистрация</a></p>
    <div style="margin-top:20px; text-align:center;">
        <a href='/public-schedule' class='public-btn' style='display:inline-block; width:auto; font-size:14px;'>Расписание групп</a>
    </div>
    """ + contact_info + """
    </div></div>"""

@app.route('/register', methods=['GET','POST'])
def register():
    if request.method=='POST':
        username = request.form.get('username', '')
        password = request.form.get('password', '')
        confirm_password = request.form.get('confirm_password', '')

        if not username or not password:
            return STYLE+"<div class='container'><div class='glass'><h2>Ошибка</h2><p>Заполните поля</p><a href='/register'>Назад</a></div></div>"
        if password != confirm_password:
            return STYLE+"<div class='container'><div class='glass'><h2>Ошибка</h2><p>Пароли не совпадают</p><a href='/register'>Назад</a></div></div>"

        success, message = register_user(username, password)
        if success:
            if username == "director":
                return STYLE+f"""<div class='container'><div class='glass'><h2>Успешно!</h2><p>{message}</p><a href='/login' class='view-btn'>Войти</a></div></div>"""
            else:
                return STYLE+f"""<div class='container'><div class='glass'><h2>Заявка отправлена</h2><p>{message}</p><a href='/login' class='view-btn'>На вход</a></div></div>"""
        else:
            return STYLE+f"<div class='container'><div class='glass'><h2>Ошибка</h2><p>{message}</p><a href='/register'>Назад</a></div></div>"

    contact_info = """
    <div class='contact-info'>
        <strong>Контакты:</strong><br>
        Директор: +7 116 116 67 52
    </div>
    """
    return STYLE+f"""<div class='container'><div class='glass'><h2>Регистрация</h2>
    <form method='post'>
        <input name='username' placeholder='Логин'>
        <input name='password' type='password' placeholder='Пароль'>
        <input name='confirm_password' type='password' placeholder='Повтор пароля'>
        <button>Создать аккаунт</button>
    </form>
    <p style='margin-top:15px; text-align:center;'>Есть аккаунт? <a href='/login' style='color:#a5b4fc;'>Войти</a></p>
    <div style="margin-top:20px; text-align:center;">
        <a href='/public-schedule' class='public-btn' style='display:inline-block; width:auto; font-size:14px;'>Расписание групп</a>
    </div>
    """ + contact_info + """
    </div></div>"""

