@app.route('/grades')
def grades_page():
    if 'user' not in session: return redirect('/login')
    username = session['user']
    nav = get_nav_for_user(username)
    right_panel = get_right_panel_for_user(username)

    if username == "director":
        groups_map = {}
        for user, data in STUDENTS.items():
            if user == "director": continue
            g = data.get("group", "Без группы")
            if g not in groups_map: groups_map[g] = []
            groups_map[g].append(user)

        html = "<div class='container' style='margin-top:100px;'><h1>Успеваемость</h1>"
        html += "<div class='glass'><h2>Группы</h2>"
        html += "<ul class='group-list'>"
        for group in sorted(groups_map.keys()):
            count = len(groups_map[group])
            html += f"<li class='group-item' onclick=\"window.location.href='/grades/group/{group}'\"><span>{group}</span> <span style='opacity:0.6;'>({count} чел.) →</span></li>"
        html += "</ul></div></div>"
        return STYLE+DIRECTOR_LEFT_PANEL_CONTENT+nav+right_panel+html

    student_grades = STUDENTS.get(username, {}).get("grades", {})
    if not student_grades:
        msg = "<div class='container'><div class='glass'><h2>Нет оценок</h2></div></div>"
        return STYLE + LEFT_PANEL_CONTENT + nav + right_panel + msg

    html="<div class='container' style='margin-top:100px;'><h1>Мои оценки</h1><div class='glass table-wrap'><table>"
    html+="<tr><th style='min-width:200px; text-align:left; padding-left:20px;'>Предмет</th>"
    for i in range(1,21): html+=f"<th>ПЗ.{i}</th>"
    html+="<th>Ср. балл</th><th>Итог</th></tr>"

    for subj,data in student_grades.items():
        html+=f"<tr><td style='text-align:left; padding-left:20px; font-weight:500;'>{subj}</td>"
        pz=data["pz"]
        filled=[x for x in pz if x is not None]
        for v in pz:
            if v is not None:
                cls = "grade-good" if v >= 80 else ("grade-avg" if v >= 50 else "grade-bad")
                html+=f"<td class='{cls}'>{v}</td>"
            else:
                html+=f"<td>-</td>"
        avg = int(sum(filled)/len(filled)) if filled else 0
        final_cls = "grade-good" if avg >= 80 else ("grade-avg" if avg >= 50 else "grade-bad")
        html+=f"<td class='{final_cls}' style='font-weight:bold; font-size:16px;'>{avg}</td><td class='{final_cls}' style='font-weight:bold; font-size:16px;'>{avg}</td></tr>"

    html+="</table></div></div>"
    return STYLE + LEFT_PANEL_CONTENT + nav + right_panel + html

@app.route('/grades/group/<group_name>')
def grades_group_list(group_name):
    if 'user' not in session or session['user'] != 'director':
        return redirect('/grades')

    nav = get_nav_for_user('director')
    right_panel = get_right_panel_for_user('director')

    students_in_group = [u for u, d in STUDENTS.items() if d.get('group') == group_name and u != 'director']

    html = f"<div class='container' style='margin-top:100px;'><h1>Группа {group_name}</h1>"
    html += "<div class='glass'><h2>Студенты</h2>"
    html += "<ul class='student-list'>"
    for student in sorted(students_in_group):
        html += f"<li class='student-item' onclick=\"window.location.href='/grades/student/{student}'\"><span>{student}</span> <span style='opacity:0.6;'>→</span></li>"
    html += "</ul>"
    html += f"<a href='/grades' class='view-btn' style='margin-top:15px;'>← Назад</a>"
    html += "</div></div>"

    return STYLE+DIRECTOR_LEFT_PANEL_CONTENT+nav+right_panel+html

@app.route('/grades/student/<student_username>')
def grades_student(student_username):
    if 'user' not in session: return redirect('/login')
    username = session['user']
    if username != "director": return redirect('/grades')

    nav = get_nav_for_user(username)
    right_panel = get_right_panel_for_user(username)

    if student_username not in STUDENTS:
        return STYLE+DIRECTOR_LEFT_PANEL_CONTENT+nav+right_panel+"<div class='container'><div class='glass'><h2>Ошибка</h2><p>Студент не найден</p><a href='/grades'>Назад</a></div></div>"

    student_grades = STUDENTS[student_username].get("grades", {})
    group = STUDENTS[student_username].get("group", "Неизвестная группа")

    html=f"<div class='container' style='margin-top:100px;'><h1>Оценки: {student_username}</h1>"
    html += f"<div class='glass' style='margin-bottom:20px;'><strong>Группа:</strong> {group}</div>"

    if not student_grades:
        html += "<div class='glass'>Нет данных</div>"
    else:
        html+="<div class='glass table-wrap'><table>"
        html+="<tr><th style='min-width:200px; text-align:left; padding-left:20px;'>Предмет</th>"
        for i in range(1,21): html+=f"<th>ПЗ.{i}</th>"
        html+="<th>Ср. балл</th><th>Итог</th></tr>"

        for subj,data in student_grades.items():
            html+=f"<tr><td style='text-align:left; padding-left:20px; font-weight:500;'>{subj}</td>"
            pz=data["pz"]
            filled=[x for x in pz if x is not None]
            for v in pz:
                if v is not None:
                    cls = "grade-good" if v >= 80 else ("grade-avg" if v >= 50 else "grade-bad")
                    html+=f"<td class='{cls}'>{v}</td>"
                else:
                    html+=f"<td>-</td>"
            avg = int(sum(filled)/len(filled)) if filled else 0
            final_cls = "grade-good" if avg >= 80 else ("grade-avg" if avg >= 50 else "grade-bad")
            html+=f"<td class='{final_cls}' style='font-weight:bold; font-size:16px;'>{avg}</td><td class='{final_cls}' style='font-weight:bold; font-size:16px;'>{avg}</td></tr>"
        html+="</table></div>"

    back_link = f'/grades/group/{group}' if group != "Неизвестная группа" else '/grades'
    html += f"<a href='{back_link}' class='view-btn' style='margin-top:15px;'>← Назад</a></div>"
    return STYLE+DIRECTOR_LEFT_PANEL_CONTENT+nav+right_panel+html

@app.route('/materials')
def materials():
    if 'user' not in session: return redirect('/login')
    username = session['user']
    nav = get_nav_for_user(username)
    right_panel = get_right_panel_for_user(username)

    html = "<div class='container' style='margin-top:90px;'><h1>Учебные материалы</h1>"

    subjects_to_show = []

    if username == 'director':
        # Директор видит ВСЕ предметы
        subjects_to_show = ALL_SUBJECTS
        html += "<div class='glass'><p style='color:#a5b4fc;'>Режим администратора: отображаются материалы по всем дисциплинам колледжа.</p></div>"
    else:
        # Студент видит только свои предметы
        student_data = STUDENTS.get(username, {})
        spec_code = student_data.get("specialty")
        if spec_code and spec_code in SPECIALTIES:
            subjects_to_show = SPECIALTIES[spec_code]
        else:
            # Для старых аккаунтов или если спец не найдена
            subjects_to_show = ["Общие материалы", "Физкультура", "Безопасность жизнедеятельности"]

    html += "<div class='schedule-grid'>"
    for subj in subjects_to_show:
        html += f"""
        <div class='day-card' style='cursor:pointer;' onclick="alert('Материалы по предмету {subj} скоро будут добавлены')">
            <h3 style='color:#fff;'>{subj}</h3>
            <p style='font-size:13px; opacity:0.7;'>Лекции, методички и практические работы</p>
            <div style='margin-top:15px;'><span class='view-btn' style='font-size:12px; padding:5px 10px;'>Открыть</span></div>
        </div>
        """
    html += "</div></div>"

    if username == 'director':
        return STYLE + DIRECTOR_LEFT_PANEL_CONTENT + nav + right_panel + html
    else:
        return STYLE + LEFT_PANEL_CONTENT + nav + right_panel + html

